rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isUser(uid) {
      return request.auth.uid == uid;
    }

    function isMember(groupID) {
      return request.auth.uid in get(/databases/$(database)/documents/groups/$(groupID)).data.memberIDs;
    }

    function isGroupCreator(groupID) {
      return get(/databases/$(database)/documents/groups/$(groupID)).data.creatorID == request.auth.uid;
    }

    function isPublicGroup(groupID) {
      return get(/databases/$(database)/documents/groups/$(groupID)).data.visibility == "public";
    }

    // ─── Users ──────────────────────────────────────────────────────────────

    match /users/{userID} {
      // Any authenticated user can read user docs (for search/display)
      allow read: if isAuthed();

      // Users can only write their own doc
      allow create: if isUser(userID);
      allow update: if isUser(userID);
      allow delete: if false;
    }

    // ─── Groups ─────────────────────────────────────────────────────────────

    match /groups/{groupID} {
      // Public groups: any authed user can read
      // Private groups: only members can read
      allow read: if isAuthed() && (
        resource.data.visibility == "public" ||
        request.auth.uid in resource.data.memberIDs
      );

      // Any authenticated user can create a group
      allow create: if isAuthed() &&
        request.resource.data.creatorID == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIDs;

      // Members can join public groups (add themselves to memberIDs only)
      // Creator can do anything
      allow update: if isAuthed() && (
        // Creator can update any field
        resource.data.creatorID == request.auth.uid ||
        // Members of public groups can add themselves
        (
          resource.data.visibility == "public" &&
          request.auth.uid in resource.data.memberIDs == false &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberIDs"]) &&
          request.resource.data.memberIDs == resource.data.memberIDs.concat([request.auth.uid])
        ) ||
        // Members can update memberIDs when leaving
        (
          request.auth.uid in resource.data.memberIDs &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberIDs"]) &&
          !(request.auth.uid in request.resource.data.memberIDs)
        )
      );

      // Only the creator can delete the group
      allow delete: if isAuthed() && resource.data.creatorID == request.auth.uid;
    }

    // ─── Events ─────────────────────────────────────────────────────────────

    match /events/{eventID} {
      // Only group members can read events
      allow read: if isAuthed() && isMember(resource.data.groupID);

      // Only group members can create events
      allow create: if isAuthed() &&
        isMember(request.resource.data.groupID) &&
        request.resource.data.creatorID == request.auth.uid;

      // Group members can update RSVP field; creator can update anything
      allow update: if isAuthed() && isMember(resource.data.groupID) && (
        resource.data.creatorID == request.auth.uid ||
        // Allow updating only the rsvps field
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["rsvps"])
      );

      // Only the event creator can delete
      allow delete: if isAuthed() && resource.data.creatorID == request.auth.uid;
    }

    // ─── Invites ────────────────────────────────────────────────────────────

    match /invites/{inviteID} {
      // Invited user, inviting user, and group members can read
      allow read: if isAuthed() && (
        resource.data.invitedUserID == request.auth.uid ||
        resource.data.invitedByUserID == request.auth.uid ||
        isMember(resource.data.groupID)
      );

      // Only members of a private group can create invites
      allow create: if isAuthed() &&
        !isPublicGroup(request.resource.data.groupID) &&
        isMember(request.resource.data.groupID) &&
        request.resource.data.invitedByUserID == request.auth.uid &&
        request.resource.data.status == "pending";

      // Only the invited user can accept/decline; inviter can also update (cancel)
      allow update: if isAuthed() && (
        // Invited user can accept or decline
        (
          resource.data.invitedUserID == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]) &&
          request.resource.data.status in ["accepted", "declined"]
        )
      );

      // Inviter can cancel (delete) their own pending invite
      allow delete: if isAuthed() &&
        resource.data.invitedByUserID == request.auth.uid &&
        resource.data.status == "pending";
    }
  }
}
